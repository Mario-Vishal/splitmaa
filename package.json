{
  "name": "splitmaa",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "mobile:start": "pnpm --filter mobile start",
    "mobile:web": "pnpm --filter mobile web",
    "mobile:android": "pnpm --filter mobile android",
    "mobile:android:native": "pnpm --filter mobile android:native",
    "mobile:ios": "pnpm --filter mobile ios",
    "mobile:ios:native": "pnpm --filter mobile ios:native",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "eval:smoke": "python tools/evals/run_eval.py --dataset datasets/splitmaa_functiongemma/test.jsonl --self-test-with-expected --limit 50",
    "eval:functiongemma:self": "python tools/evals/run_eval.py --dataset datasets/splitmaa_functiongemma/test.jsonl --self-test-with-expected",
    "eval:functiongemma": "python tools/evals/run_eval.py --dataset datasets/splitmaa_functiongemma/test.jsonl"
  }
}
